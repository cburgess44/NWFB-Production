<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>BlockAppointmentCreationByScheduled</fullName>
    <active>false</active>
    <errorConditionFormula>AND( TEXT(Status__c) = &apos;Scheduled&apos; ,  Service__r.NumberOfScheduledAppointments__c &gt; 0,  ISNEW() )</errorConditionFormula>
    <errorMessage>There are already an appointment scheduled for this request...</errorMessage>
</ValidationRule>
