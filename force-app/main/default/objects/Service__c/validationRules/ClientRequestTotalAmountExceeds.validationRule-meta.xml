<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ClientRequestTotalAmountExceeds</fullName>
    <active>false</active>
    <errorConditionFormula>IF( RecordType.DeveloperName = &apos;ClientRequest&apos;, 
    TotalAmount__c &gt; TotalPaid__c , 
    false
)</errorConditionFormula>
    <errorMessage>Total Amount exceeds Payee Total</errorMessage>
</ValidationRule>
