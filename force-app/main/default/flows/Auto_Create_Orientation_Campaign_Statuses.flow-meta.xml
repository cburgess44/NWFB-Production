<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <decisions>
        <name>Check_Record_Type</name>
        <label>Check Record Type</label>
        <locationX>176</locationX>
        <locationY>335</locationY>
        <defaultConnectorLabel>Not Orientation</defaultConnectorLabel>
        <rules>
            <name>Is_Orientation</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>RecordTypeDeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Orientation</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Registered_Status_As_Default</targetReference>
            </connector>
            <label>Is Orientation</label>
        </rules>
    </decisions>
    <description>Automatically creates Campaign Member Statuses (Registered, Attended, Not attended) when a new Orientation campaign is created. Sets Registered as the default status.</description>
    <environments>Default</environments>
    <formulas>
        <name>RecordTypeDeveloperName</name>
        <dataType>String</dataType>
        <expression>{!$Record.RecordType.DeveloperName}</expression>
    </formulas>
    <interviewLabel>Auto Create Orientation Campaign Statuses {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Create Orientation Campaign Statuses</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Attended_Status</name>
        <label>Create Attended Status</label>
        <locationX>50</locationX>
        <locationY>575</locationY>
        <connector>
            <targetReference>Create_Not_Attended_Status</targetReference>
        </connector>
        <inputAssignments>
            <field>CampaignId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>HasResponded</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>IsDefault</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Label</field>
            <value>
                <stringValue>Attended</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SortOrder</field>
            <value>
                <numberValue>4.0</numberValue>
            </value>
        </inputAssignments>
        <object>CampaignMemberStatus</object>
    </recordCreates>
    <recordCreates>
