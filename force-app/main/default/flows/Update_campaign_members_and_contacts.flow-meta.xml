    <textTemplates>
        <name>bodyEmail</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi, {!contact_for_emails_loop.Name}&lt;/p&gt;&lt;p&gt;Thank you for signing up for NW Furniture Bank&apos;s Virtual Referral Partner Orientation on {!get_campaign.StartDate} Please budget about 90 minutes for our meeting.&amp;nbsp;&lt;u&gt;Individuals who arrive more than 5 minutes late will not be able to join the meeting.&lt;/u&gt;&lt;/p&gt;&lt;p&gt;Below is the Zoom meeting registration link; you will receive the meeting link after completion.&amp;nbsp;Please e-mail us at&amp;nbsp;&lt;a href=&quot;mailto:orientation@nwfurniturebank.org&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;orientation@nwfurniturebank.org&lt;/a&gt;&amp;nbsp;if you have any trouble accessing it.&amp;nbsp;&lt;/p&gt;&lt;p&gt;See you soon!&lt;/p&gt;&lt;p&gt;You are invited to a Zoom meeting.&amp;nbsp;&lt;/p&gt;&lt;p&gt;When: &lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(68, 68, 68);&quot;&gt;{!get_campaign.StartDate}&lt;/span&gt; Pacific Time (US and Canada)&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;So that we can give you credit for attending&lt;/u&gt;&lt;/strong&gt;, please register through Zoom for this meeting:&amp;nbsp;&lt;/p&gt;&lt;p&gt;{!get_campaign.Zoom_Link__c}&lt;/p&gt;&lt;p&gt;After registering, you will receive a confirmation email containing information about joining the meeting.&lt;/p&gt;</text>
