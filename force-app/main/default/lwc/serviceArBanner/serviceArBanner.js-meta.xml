<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Service AR Banner</masterLabel>
    <description>Displays a colored banner on Service records showing AR aging status. Red for 90+ days, orange for 61-90 days, yellow for 31-60 days, gray for written-off balances. Hidden when fully paid.</description>
    <targets>
        <target>lightning__RecordPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Service__c</object>
            </objects>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
